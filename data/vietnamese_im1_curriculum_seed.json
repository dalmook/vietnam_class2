    {
      "id": "l5-s-01",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Em sống ở đâu?",
      "meaningKo": "너는 어디에서 사니?",
      "audioSrc": "/audio/lesson-5/s01.mp3"
    },
    {
      "id": "l5-s-02",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Em sống ở đường Hai Bà Trưng.",
      "meaningKo": "저는 하이바쯩길에 살아요.",
      "audioSrc": "/audio/lesson-5/s02.mp3"
    },
    {
      "id": "l5-s-03",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Nhà anh ở Seoul.",
      "meaningKo": "오빠 집은 서울에 있어.",
      "audioSrc": "/audio/lesson-5/s03.mp3"
    },
    {
      "id": "l5-s-04",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Vì anh đang làm việc ở công ti Hàn Quốc tại Hà Nội nên thuê nhà ở đây.",
      "meaningKo": "형이 하노이에 있는 한국 회사에서 일하고 있어서 여기에서 집을 얻었어.",
      "audioSrc": "/audio/lesson-5/s04.mp3"
    },
    {
      "id": "l5-s-05",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Anh sống với ai?",
      "meaningKo": "오빠는 누구와 살아요?",
      "audioSrc": "/audio/lesson-5/s05.mp3"
    },
    {
      "id": "l5-s-06",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Anh sống với vợ, một con gái và một con trai.",
      "meaningKo": "오빠는 아내, 딸 한 명 그리고 아들 한 명과 살아.",
      "audioSrc": "/audio/lesson-5/s06.mp3"
    },
    {
      "id": "l5-s-07",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Em gái của em đẹp quá nhỉ.",
      "meaningKo": "네 여동생 너무 예쁘네.",
      "audioSrc": "/audio/lesson-5/s07.mp3"
    },
    {
      "id": "l5-s-08",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Em ấy vừa đẹp vừa thông minh.",
      "meaningKo": "그 애는 예쁘면서 총명해요.",
      "audioSrc": "/audio/lesson-5/s08.mp3"
    },
    {
      "id": "l5-s-09",
      "type": "sentence",
      "stageSlug": "numbers-time-date",
      "text": "Em ấy bao nhiêu tuổi?",
